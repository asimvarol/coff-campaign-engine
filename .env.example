# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coff_campaign_engine"
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Services (Optional - graceful fallback when empty)
# OpenAI: concept generation, brand voice analysis, insights, best posting times
OPENAI_API_KEY=""
# Fal.ai: image generation (nano-banana-2), background removal (birefnet)
FAL_AI_KEY=""

# Social Platform APIs (Optional - OAuth for publishing)
META_APP_ID=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN="coff-webhook-verify"
X_CLIENT_ID=""
X_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# App URLs
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3002"

# Feature Flags
ENABLE_AUTOPILOT="true"
ENABLE_AGENCY_MODE="true"
