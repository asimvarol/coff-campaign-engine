# Database
DATABASE_URL="postgresql://user:password@localhost:5432/coff_campaign_engine"

# Redis
REDIS_URL="redis://localhost:6379"

# AI Services
FAL_AI_KEY="your-fal-ai-key"
OPENAI_API_KEY="your-openai-api-key"

# Social Platform APIs
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
TIKTOK_CLIENT_KEY="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
X_API_KEY="your-x-api-key"
X_API_SECRET="your-x-api-secret"
PINTEREST_APP_ID="your-pinterest-app-id"
PINTEREST_APP_SECRET="your-pinterest-app-secret"
YOUTUBE_CLIENT_ID="your-youtube-client-id"
YOUTUBE_CLIENT_SECRET="your-youtube-client-secret"

# Authentication (use your existing Coff auth)
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-nextauth-secret"

# Storage (S3 / R2)
S3_ACCESS_KEY_ID="your-s3-access-key"
S3_SECRET_ACCESS_KEY="your-s3-secret-key"
S3_BUCKET="coff-campaign-assets"
S3_REGION="us-east-1"
S3_ENDPOINT="https://s3.amazonaws.com" # or Cloudflare R2 endpoint

# App URLs
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3002"

# Email (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Coff Campaign Engine <noreply@coff.ai>"

# Monitoring
SENTRY_DSN="your-sentry-dsn"

# Feature Flags
ENABLE_AUTOPILOT="true"
ENABLE_AGENCY_MODE="true"
